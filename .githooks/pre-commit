#!/usr/bin/env bash
# .githooks/pre-commit — DoD safety net (gates 1-5) for project commits.
#
# Activated via: git config core.hooksPath .githooks  (run once after `git init`).
# Bypass:        SKIP_HOOK=1 git commit ...           (use sparingly, justify in commit body).
# Never use --no-verify (kit's commit-safety protocol forbids it).
#
# Gates enforced:
#   1. Lint clean         (per-stack)
#   2. Tests green        (per-stack)
#   3. Build OK           (per-stack)
#   4. No type-escape     (per-language grep of staged blobs)
#   5. No debug logs      (per-language grep of staged blobs)
#   5b. Architecture      (domain dirs must not import from UI/endpoint layers)
#
# Gates 6 / 6b / 7 / 8 (CHECKLIST sync / doc drift / AI_USAGE / commit message)
# remain in chat-time Procedure 1 — the hook does NOT enforce them.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# ----- Bypass switches -----
if [ "${SKIP_HOOK:-0}" = "1" ]; then
  echo "[pre-commit] SKIP_HOOK=1 — bypassing all gates (justify in commit body)"
  exit 0
fi
# TDD Red phase: skip Gate 2 only (tests expected to fail before implementation).
# Usage: TDD_RED=1 git commit -m "test: failing test for <feature> [§N]"
TDD_RED="${TDD_RED:-0}"
if [ "$TDD_RED" = "1" ]; then
  echo "[pre-commit] TDD_RED=1 — Gate 2 (tests) will be skipped (Red phase)"
fi

# ----- Docs-only detection (Phase A escape) -----
staged_files=$(git diff --cached --name-only --diff-filter=AM)
if [ -z "$staged_files" ]; then
  exit 0
fi

# A commit is docs-only when EVERY staged path is under docs/, *.md at root,
# .gitignore, LICENSE, or hook/skill/script infrastructure.
non_docs=$(echo "$staged_files" | grep -vE '^(docs/|README\.md|CLAUDE\.md|AGENTS\.md|LICENSE|\.gitignore|\.claude/skills/|\.githooks/|scripts/)' || true)
DOCS_ONLY=0
[ -z "$non_docs" ] && DOCS_ONLY=1

# ----- Stack detection (first match wins) -----
STACK=none
[ -f package.json ]                                && STACK=node
[ "$STACK" = "none" ] && [ -f pyproject.toml ]     && STACK=python
[ "$STACK" = "none" ] && [ -f requirements.txt ]   && STACK=python
[ "$STACK" = "none" ] && [ -f Cargo.toml ]         && STACK=rust
[ "$STACK" = "none" ] && [ -f go.mod ]             && STACK=go
[ "$STACK" = "none" ] && [ -f pom.xml ]            && STACK=java
[ "$STACK" = "none" ] && [ -f build.gradle ]       && STACK=java
[ "$STACK" = "none" ] && [ -f build.gradle.kts ]   && STACK=java

echo "[pre-commit] stack=$STACK docs_only=$DOCS_ONLY"

# ----- Gates 1-3 — lint / test / build per stack -----
run_gates_123() {
  case "$STACK" in
    node)
      if grep -q '"lint"' package.json; then
        npm run -s lint || { echo "[gate1] FAIL: lint"; exit 1; }
      elif echo "$staged_files" | grep -q '^src/'; then
        echo "[gate1] FAIL: src/ code but no lint script — add one (or SKIP_HOOK=1)"; exit 1
      else echo "[gate1] ⚠ no lint script — coding-style NOT enforced"
      fi
      # CI=true makes vitest/jest/CRA run once and exit instead of entering watch mode (commit would hang).
      if [ "$TDD_RED" = "1" ]; then
        echo "[gate2] (skipped: TDD_RED=1 — Red phase, tests expected to fail)"
      elif grep -q '"test:run"' package.json; then
        CI=true npm run -s test:run || { echo "[gate2] FAIL: tests"; exit 2; }
      elif grep -q '"test"' package.json; then
        CI=true npm test --silent || { echo "[gate2] FAIL: tests"; exit 2; }
      else echo "[gate2] (skipped: no test script)"
      fi
      if grep -q '"build"' package.json; then
        npm run -s build || { echo "[gate3] FAIL: build"; exit 3; }
      else echo "[gate3] (skipped: no build script)"
      fi
      ;;
    python)
      if command -v ruff >/dev/null 2>&1; then
        ruff check . || { echo "[gate1] FAIL: ruff"; exit 1; }
      else echo "[gate1] (skipped: ruff not installed)"
      fi
      if [ "$TDD_RED" = "1" ]; then
        echo "[gate2] (skipped: TDD_RED=1 — Red phase)"
      elif command -v pytest >/dev/null 2>&1; then
        pytest -q || { echo "[gate2] FAIL: pytest"; exit 2; }
      else echo "[gate2] (skipped: pytest not installed)"
      fi
      if [ -f pyproject.toml ] && grep -q '^\[build-system\]' pyproject.toml; then
        python -m build --sdist -o /tmp/.pre-commit-build >/dev/null || { echo "[gate3] FAIL: build"; exit 3; }
      else echo "[gate3] (skipped: no [build-system])"
      fi
      ;;
    rust)
      cargo clippy --all-targets -- -D warnings || { echo "[gate1] FAIL: clippy"; exit 1; }
      if [ "$TDD_RED" = "1" ]; then
        echo "[gate2] (skipped: TDD_RED=1 — Red phase)"
      else
        cargo test --quiet                      || { echo "[gate2] FAIL: tests"; exit 2; }
      fi
      cargo build                                || { echo "[gate3] FAIL: build"; exit 3; }
      ;;
    go)
      go vet ./...    || { echo "[gate1] FAIL: vet"; exit 1; }
      if [ "$TDD_RED" = "1" ]; then echo "[gate2] (skipped: TDD_RED=1 — Red phase)"
      else go test ./... || { echo "[gate2] FAIL: tests"; exit 2; }
      fi
      go build ./...  || { echo "[gate3] FAIL: build"; exit 3; }
      ;;
    java)
      if [ -f pom.xml ]; then
        if [ "$TDD_RED" = "1" ]; then echo "[gate2] (skipped: TDD_RED=1 — Red phase)"
        else mvn -q test || { echo "[gate2] FAIL: tests"; exit 2; }
        fi
        mvn -q -DskipTests package || { echo "[gate3] FAIL: build"; exit 3; }
      else
        ./gradlew check assemble || { echo "[gate2/3] FAIL: gradle check assemble"; exit 2; }
      fi
      ;;
    none)
      echo "[pre-commit] no stack detected — skipping gates 1-3 (Phase A is fine)"
      ;;
  esac
}

# ----- Gates 4-5 — type-escape + debug-log on staged blobs only -----
run_gates_45() {
  files=$(git diff --cached --name-only --diff-filter=AM)
  [ -z "$files" ] && return 0

  type_hits=0
  log_hits=0

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ ! -f "$f" ] && continue
    case "$f" in
      *.ts|*.tsx)
        if git show ":$f" 2>/dev/null | grep -nE ': any($|[^a-zA-Z])|as any| any\[\]' | grep -v '// allow:' > /tmp/.pc-gate4 2>/dev/null; then
          if [ -s /tmp/.pc-gate4 ]; then
            echo "[gate4] $f:"
            cat /tmp/.pc-gate4 | sed 's/^/    /'
            type_hits=$((type_hits+1))
          fi
        fi
        if git show ":$f" 2>/dev/null | grep -n 'console\.log' | grep -v '// allow:' > /tmp/.pc-gate5 2>/dev/null; then
          if [ -s /tmp/.pc-gate5 ]; then
            echo "[gate5] $f:"
            cat /tmp/.pc-gate5 | sed 's/^/    /'
            log_hits=$((log_hits+1))
          fi
        fi
        ;;
      *.py)
        if git show ":$f" 2>/dev/null | grep -nE 'cast\(|# type: ignore' | grep -v '# allow:' > /tmp/.pc-gate4 2>/dev/null; then
          if [ -s /tmp/.pc-gate4 ]; then
            echo "[gate4] $f:"
            cat /tmp/.pc-gate4 | sed 's/^/    /'
            type_hits=$((type_hits+1))
          fi
        fi
        if git show ":$f" 2>/dev/null | grep -nE '^[^#]*\bprint\(' | grep -v '# allow:' > /tmp/.pc-gate5 2>/dev/null; then
          if [ -s /tmp/.pc-gate5 ]; then
            echo "[gate5] $f:"
            cat /tmp/.pc-gate5 | sed 's/^/    /'
            log_hits=$((log_hits+1))
          fi
        fi
        ;;
      *.rs)
        if git show ":$f" 2>/dev/null | grep -nE 'unsafe |#\[allow\(' | grep -v '// allow:' > /tmp/.pc-gate4 2>/dev/null; then
          if [ -s /tmp/.pc-gate4 ]; then
            echo "[gate4] $f:"
            cat /tmp/.pc-gate4 | sed 's/^/    /'
            type_hits=$((type_hits+1))
          fi
        fi
        if git show ":$f" 2>/dev/null | grep -n 'dbg!' | grep -v '// allow:' > /tmp/.pc-gate5 2>/dev/null; then
          if [ -s /tmp/.pc-gate5 ]; then
            echo "[gate5] $f:"
            cat /tmp/.pc-gate5 | sed 's/^/    /'
            log_hits=$((log_hits+1))
          fi
        fi
        ;;
      *.go)
        if git show ":$f" 2>/dev/null | grep -n 'fmt\.Println' | grep -v '// allow:' > /tmp/.pc-gate5 2>/dev/null; then
          if [ -s /tmp/.pc-gate5 ]; then
            echo "[gate5] $f:"
            cat /tmp/.pc-gate5 | sed 's/^/    /'
            log_hits=$((log_hits+1))
          fi
        fi
        ;;
      *.java)
        if git show ":$f" 2>/dev/null | grep -n '@SuppressWarnings' | grep -v '// allow:' > /tmp/.pc-gate4 2>/dev/null; then
          if [ -s /tmp/.pc-gate4 ]; then
            echo "[gate4] $f:"
            cat /tmp/.pc-gate4 | sed 's/^/    /'
            type_hits=$((type_hits+1))
          fi
        fi
        if git show ":$f" 2>/dev/null | grep -n 'System\.out\.println' | grep -v '// allow:' > /tmp/.pc-gate5 2>/dev/null; then
          if [ -s /tmp/.pc-gate5 ]; then
            echo "[gate5] $f:"
            cat /tmp/.pc-gate5 | sed 's/^/    /'
            log_hits=$((log_hits+1))
          fi
        fi
        ;;
    esac
  done <<EOF
$files
EOF

  rm -f /tmp/.pc-gate4 /tmp/.pc-gate5

  if [ "$type_hits" -gt 0 ]; then
    echo "[gate4] FAIL: $type_hits files with type-escape (add '// allow:' or '# allow:' to permit)"
    exit 4
  fi
  if [ "$log_hits" -gt 0 ]; then
    echo "[gate5] FAIL: $log_hits files with debug logs (add '// allow:' or '# allow:' to permit)"
    exit 5
  fi
}

# ----- Gate 5b — Architecture: domain dirs must not import from UI/endpoint layers -----
run_gate_5b() {
  local ui_pattern='from ['"'"'"][^'"'"'"]*/(components|pages|api|routes|views|app)[/'"'"'"]'
  local domain_dirs="src/lib src/utils src/helpers src/shared"
  local violations=0
  local staged
  staged=$(git diff --cached --name-only --diff-filter=AM)

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ ! -f "$f" ] && continue
    case "$f" in
      *.ts|*.tsx|*.js|*.jsx|*.py) ;;
      *) continue ;;
    esac
    local in_domain=0
    for dir in $domain_dirs; do
      case "$f" in "$dir"/*) in_domain=1; break ;; esac
    done
    [ "$in_domain" = "0" ] && continue

    if git show ":$f" 2>/dev/null \
        | grep -nE "$ui_pattern" \
        | grep -v '// allow:\|# allow:' > /tmp/.pc-gate5b 2>/dev/null; then
      if [ -s /tmp/.pc-gate5b ]; then
        echo "[gate5b] $f:"
        sed 's/^/    /' /tmp/.pc-gate5b
        violations=$((violations+1))
      fi
    fi
  done <<EOF
$staged
EOF

  rm -f /tmp/.pc-gate5b

  if [ "$violations" -gt 0 ]; then
    echo "[gate5b] FAIL: domain/utility layer imports from UI/endpoint layer"
    echo "         Add '// allow:' comment to permit an intentional exception."
    exit 6
  fi
}

# ----- Run gates -----
if [ "$DOCS_ONLY" = "1" ]; then
  echo "[pre-commit] docs-only commit — running gate 5 only (cheap scan of any staged code)"
  run_gates_45
  echo "[pre-commit] OK"
  exit 0
fi

run_gates_123
run_gates_45
run_gate_5b
echo "[pre-commit] all auto gates passed"
